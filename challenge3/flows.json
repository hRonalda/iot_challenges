        "id": "90c5d42485c9ad6a",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Select smallest source",
        "func": "let rows = msg.payload;\n\nif (!rows || rows.length === 0) {\n    return null;\n}\n\nlet minSource = rows\n    .map(r => r.Source)\n    .sort((a, b) => parseInt(a, 16) - parseInt(b, 16))[0];\n\nlet selected = rows\n    .filter(r => r.Source === minSource)\n    .sort((a, b) => parseInt(a.Destination, 16) - parseInt(b.Destination, 16));\n\nmsg.payload = selected.map(r => ({\n    source: r.Source,\n    destination: r.Destination,\n    cost: r.Cost\n}));\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
