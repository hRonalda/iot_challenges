    {
        "id": "212b3e5ece8ae3e9",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Extract Link Status Costs",
        "func": "let row = msg.csv_row || msg.payload;\n\nlet packetType = row[\"Packet Type\"];\nlet cmd = row[\"Command String\"];\n\nif (!packetType || !packetType.includes(\"Link Status\")) {\n    return null;\n}\n\nif (!cmd) {\n    return null;\n}\n\nlet obj;\ntry {\n    obj = Function(\"return \" + cmd)();\n} catch (e) {\n    node.warn(\"Cannot parse Link Status Command String\");\n    return null;\n}\n\nlet source = row[\"Source Address ZigBee\"];\n\nif (!source || !obj[\"Links\"]) {\n    return null;\n}\n\nlet links = obj[\"Links\"];\n\nlet costTable = flow.get(\"outgoing_cost_table\") || {};\n\nfor (let link of links) {\n    let destination = link[\"Address\"];\n    let cost = link[\"Outgoing Cost\"];\n\n    let key = source + \"_\" + destination;\n\n    costTable[key] = {\n        source: source,\n        destination: destination,\n        cost: cost\n    };\n}\n\nflow.set(\"outgoing_cost_table\", costTable);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 780,
