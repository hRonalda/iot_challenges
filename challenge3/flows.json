    {
        "id": "a6ad8aa2841ccede",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Export outgoing costs",
        "func": "let table = flow.get(\"outgoing_cost_table\") || {};\nlet rows = Object.values(table);\n\nrows.sort((a, b) => {\n    let sa = parseInt(a.source, 16);\n    let sb = parseInt(b.source, 16);\n    if (sa !== sb) return sa - sb;\n\n    let da = parseInt(a.destination, 16);\n    let db = parseInt(b.destination, 16);\n    return da - db;\n});\n\nmsg.payload = rows.map((r, i) => ({\n    \"No.\": i + 1,\n    \"Source\": r.source,\n    \"Destination\": r.destination,\n    \"Cost\": r.cost\n}));\n\nreturn msg;",
