    {
        "id": "76695cab7c46c342",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Extract RMS Elements",
        "func": "let row = msg.csv_row || msg.payload;\nlet cmd = row[\"Command String\"];\n\nif (!cmd) return null;\n\nlet obj;\ntry {\n    obj = Function(\"return \" + cmd)();\n} catch (e) {\n    node.warn(\"Cannot parse Command String\");\n    return null;\n}\n\nlet attrs = obj[\"Attribute\"];\nlet statuses = obj[\"Status\"];\nlet dataTypes = obj[\"Data Type\"];\n\nif (!Array.isArray(attrs)) attrs = [attrs];\nif (!Array.isArray(statuses)) statuses = [statuses];\nif (!Array.isArray(dataTypes)) dataTypes = [dataTypes];\n\nlet values = [];\n\nif (obj[\"Int16\"] !== undefined) {\n    values = values.concat(Array.isArray(obj[\"Int16\"]) ? obj[\"Int16\"] : [obj[\"Int16\"]]);\n}\n\nif (obj[\"Uint16\"] !== undefined) {\n    values = values.concat(Array.isArray(obj[\"Uint16\"]) ? obj[\"Uint16\"] : [obj[\"Uint16\"]]);\n}\n\nlet wanted = [\"Active Power\", \"RMS Current\", \"RMS Voltage\"];\nlet results = [];\n\nfor (let i = 0; i < attrs.length; i++) {\n    let cleanAttr = String(attrs[i]).replace(/\\s*\\(0x[0-9a-fA-F]+\\)/, \"\");\n\n    if (!wanted.includes(cleanAttr)) continue;\n\n    let cleanStatus = String(statuses[i] || \"\").replace(/\\s*\\(0x[0-9a-fA-F]+\\)/, \"\");\n    let cleanType = String(dataTypes[i] || \"\").replace(/\\s*\\(0x[0-9a-fA-F]+\\)/, \"\");\n    let rawValue = values[i] !== undefined ? String(values[i]) : \"\";\n    let cleanValue = rawValue.replace(/\\s*\\(0x[0-9a-fA-F]+\\)/, \"\");\n\n    if (!cleanStatus || !cleanType || cleanValue === \"\") {\n        continue;\n    }\n\n    results.push({\n        timestamp: Math.floor(Date.now() / 1000),\n        sequence: obj[\"Sequence Number\"] || \"\",\n        attribute: cleanAttr,\n        status: cleanStatus,\n        datatype: cleanType,\n        value: cleanValue\n    });\n}\n\nif (results.length === 0) return null;\n\nmsg.payload = results;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 960,
        "y": 500,
        "wires": [
            [
                "ad582ee95ff4a94a",
                "9099c49963dc34ba"
            ]
        ]
