        "id": "068152104b03940b",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Check ZBEE_ZCL and Build Payload",
        "func": "let row = msg.csv_row || msg.payload;\n\nlet cmd = row[\"Command String\"];\n\nif (!cmd || !cmd.includes(\"ZBEE_ZCL\")) {\n    return null;\n}\n\nlet devName = row[\"Device Name ZigBee Source\"];\n\nmsg.topic = \"ZigBee/\" + devName;\n\nmsg.payload = JSON.stringify({\n    timestamp: Math.floor(Date.now() / 1000),\n    id: msg.sub_id,\n    \"wpan.src\": row[\"Source Address\"],\n    \"wpan.dst\": row[\"Destination Address\"],\n    \"zbee.src\": row[\"Source Address ZigBee\"],\n    \"zbee.dst\": row[\"Destination Address ZigBee\"],\n    topic: \"ZigBee/\" + devName,\n    payload: cmd\n});\n\nreturn msg;",
