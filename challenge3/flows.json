    {
        "id": "fa3dd92baabf5f62",
        "type": "function",
        "z": "fec7735c63189767",
        "name": "Generate ID",
        "func": "// input is in the msg\n// Q1: Each message should contain in the payload a JSON-formatted string with a random\n// number(id) between 0 and 30000, and the time at which the message is generated(UNIX timestamp)\n\n// flow.set(\"id_counter\", 0);\n// flow.set(\"filtered_counter\", 0);\n// flow.set(\"outgoing_cost_table\", {});\n// return null;\n\n\n\n\nlet counter = flow.get(\"id_counter\") || 0;\n\nif (counter >= 200) {\n    return null;\n}\n\ncounter += 1;\nflow.set(\"id_counter\", counter);\n\nlet id = Math.floor(Math.random() * 30001);\nlet timestamp = Math.floor(Date.now() / 1000);\n\nmsg.payload = JSON.stringify({\n    id: id,\n    timestamp: timestamp\n});\n\nmsg.csv_row = {\n    no: counter,\n    id: id,\n    timestamp: timestamp\n};\n\nreturn msg;",
